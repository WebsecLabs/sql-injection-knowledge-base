---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import EntryList from "../components/EntryList.astro";
import Tabs from "../components/Tabs.astro";
import StructuredData from "../components/StructuredData.astro";
import { COLLECTION_TYPES, COLLECTION_LABELS } from "../utils/constants";
import { requireSiteUrl } from "../utils/siteUtils";

// Get entries from all collections
const mysqlEntries = await getCollection("mysql");
const mariadbEntries = await getCollection("mariadb");
const mssqlEntries = await getCollection("mssql");
const oracleEntries = await getCollection("oracle");
const postgresqlEntries = await getCollection("postgresql");
const extrasEntries = await getCollection("extras");

// Map entries to a convenient object
const entries = {
  mysql: mysqlEntries,
  mariadb: mariadbEntries,
  mssql: mssqlEntries,
  oracle: oracleEntries,
  postgresql: postgresqlEntries,
  extras: extrasEntries,
};

// Count total entries
const totalEntries = [
  mysqlEntries,
  mariadbEntries,
  mssqlEntries,
  oracleEntries,
  postgresqlEntries,
  extrasEntries,
].reduce((sum, arr) => sum + arr.length, 0);

// Count actual database platforms (collections with at least one entry)
const activeDatabaseCount = [
  mysqlEntries.length > 0,
  mariadbEntries.length > 0,
  mssqlEntries.length > 0,
  oracleEntries.length > 0,
  postgresqlEntries.length > 0,
].filter(Boolean).length;

// Ensure site is configured for structured data URLs
const site = requireSiteUrl(Astro.site);

// Build site URL for structured data
const siteUrl = site.href;
const searchUrl = new URL(`${import.meta.env.BASE_URL}search`, site).href;
---

<Layout
  title="SQL Injection Knowledge Base"
  showSidebar={false}
  pageType="website"
  collections={{
    mysqlEntries,
    mariadbEntries,
    mssqlEntries,
    oracleEntries,
    postgresqlEntries,
    extrasEntries,
  }}
>
  <!-- Structured Data for SEO -->
  <StructuredData
    type="website"
    siteName="SQL Injection Knowledge Base"
    siteUrl={siteUrl}
    searchUrl={searchUrl}
  />

  <div class="home-intro" transition:animate="slide">
    <h1 transition:name="page-title">SQL Injection Knowledge Base</h1>
    <p class="lead" transition:animate="fade">
      A comprehensive resource for SQL injection techniques, examples, and bypasses across multiple
      database platforms.
    </p>
    <div class="stats" transition:animate="fade">
      <div class="stat-item">
        <span class="stat-value">{totalEntries}</span>
        <span class="stat-label">Knowledge Base Entries</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">{activeDatabaseCount}</span>
        <span class="stat-label">Database Platforms</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">100%</span>
        <span class="stat-label">Open Source Resources</span>
      </div>
    </div>

    <div class="cta-container">
      <a href={`${import.meta.env.BASE_URL}mysql/intro`} class="explore-button">
        <span>Explore Documentation</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="database-tabs" transition:animate="slide">
    <Tabs defaultTab="mysql">
      <Fragment slot="tab-list">
        {
          COLLECTION_TYPES.map((type, index) => (
            <li
              class={`tab-item ${type === "mysql" ? "active" : ""}`}
              data-tab={type}
              role="tab"
              tabindex={index === 0 ? "0" : "-1"}
              aria-selected={type === "mysql" ? "true" : "false"}
            >
              {COLLECTION_LABELS[type]}
            </li>
          ))
        }
      </Fragment>

      {
        COLLECTION_TYPES.map((type) => (
          <div class={`tab-content${type === "mysql" ? " active" : ""}`} data-tab={type}>
            <EntryList
              entries={entries[type]}
              title={type === "extras" ? "Additional Resources" : COLLECTION_LABELS[type]}
              collectionType={type}
            />
          </div>
        ))
      }
    </Tabs>
  </div>
</Layout>

<script>
  declare global {
    interface Window {
      __tabScrollAC?: AbortController;
    }
  }

  function initTabScrollIndicators() {
    window.__tabScrollAC?.abort();
    const ac = new AbortController();
    window.__tabScrollAC = ac;
    const { signal } = ac;

    const tabsContainer = document.querySelector(".database-tabs");
    const tabList = tabsContainer?.querySelector(".tab-list") as HTMLElement | null;
    if (!tabsContainer || !tabList) return;

    function updateScrollState() {
      const { scrollLeft, scrollWidth, clientWidth } = tabList!;
      const atStart = scrollLeft <= 2;
      const atEnd = scrollLeft + clientWidth >= scrollWidth - 2;

      tabsContainer!.classList.toggle("scrolled-start", atStart);
      tabsContainer!.classList.toggle("scrolled-end", atEnd);
      tabsContainer!.classList.toggle("scrolled-middle", !atStart && !atEnd);
    }

    tabList.addEventListener("scroll", updateScrollState, { passive: true, signal });
    window.addEventListener("resize", updateScrollState, { passive: true, signal });
    updateScrollState();
  }

  initTabScrollIndicators();
  document.addEventListener("astro:page-load", initTabScrollIndicators);
</script>

<style>
  .home-intro {
    background-color: var(--color-card-bg);
    border-radius: 8px;
    box-shadow: var(--shadow);
    padding: 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .home-intro h1 {
    margin-top: 0;
    font-size: 2.5rem;
    color: var(--color-primary);
    border-bottom: none;
  }

  .lead {
    font-size: 1.2rem;
    max-width: 800px;
    margin: 1rem auto 2rem;
    color: var(--color-text-muted);
  }

  .stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 3.5rem;
    margin: 2.5rem auto;
    max-width: 800px;
  }

  .cta-container {
    margin-top: 2.5rem;
    text-align: center;
  }

  .explore-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background-color: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: 600;
    text-decoration: none;
    transition:
      filter 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: 0 4px 6px rgb(43 108 176 / 20%);
  }

  .explore-button:hover {
    filter: brightness(0.9);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgb(43 108 176 / 30%);
    text-decoration: none;
  }

  .explore-button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  :global(:root.dark) .explore-button {
    background-color: #2563eb;
    box-shadow: 0 4px 6px rgb(37 99 235 / 30%);
  }

  :global(:root.dark) .explore-button:hover {
    box-shadow: 0 6px 12px rgb(37 99 235 / 40%);
  }

  .explore-button svg {
    transition: transform 0.2s ease;
  }

  .explore-button:hover svg {
    transform: translateX(3px);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 150px;
    text-align: center;
    position: relative;
  }

  .stat-value {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .stat-label {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 500;
    line-height: 1.3;
    max-width: 140px;
  }

  .database-tabs {
    margin-top: 2rem;
    position: relative;
  }

  /* Scroll fade indicator — hints at overflowing tabs on narrow viewports */
  .database-tabs::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 40px;
    height: 49px;
    background: linear-gradient(to right, transparent, var(--color-card-bg));
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.2s ease;
    z-index: 1;
  }

  .database-tabs.tabs-fit::after {
    opacity: 0;
  }

  :global(.tab-list) {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    border-bottom: 1px solid var(--color-border);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
  }

  :global(.tab-list::-webkit-scrollbar) {
    display: none;
  }

  :global(.tab-item) {
    padding: 1rem 1.5rem;
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text-muted);
    border-bottom: 3px solid transparent;
    transition:
      color 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease;
    white-space: nowrap;
    scroll-snap-align: start;
  }

  :global(.tab-item:hover) {
    color: var(--color-primary);
    background-color: var(--color-primary-tint-5);
  }

  :global(.tab-item.active) {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  :global(.tab-content) {
    display: none;
    animation: fadeIn 0.5s ease;
    margin-top: 1rem;
  }

  :global(.tab-content.active) {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (width >= 769px) {
    .database-tabs::after {
      display: none;
    }
  }

  @media (width <= 768px) {
    .home-intro {
      padding: 1.5rem;
    }

    .home-intro h1 {
      font-size: 2rem;
    }

    .lead {
      font-size: 1.1rem;
    }

    .stats {
      gap: 2rem;
      flex-direction: column;
      align-items: center;
      margin: 2rem auto;
    }

    .stat-item {
      min-width: 200px;
      padding: 0.75rem 0;
    }

    .stat-value {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 0.95rem;
      max-width: 180px;
    }

    .cta-container {
      margin-top: 1.5rem;
    }

    .explore-button {
      width: 100%;
      justify-content: center;
    }

    :global(.tab-item) {
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
    }

    .database-tabs::before,
    .database-tabs::after {
      content: "";
      position: absolute;
      top: 0;
      width: 32px;
      height: 48px;
      pointer-events: none;
      z-index: 1;
      transition: opacity 0.2s ease;
    }

    .database-tabs::before {
      left: 0;
      background: linear-gradient(to right, var(--color-card-bg), transparent);
      opacity: 0;
    }

    .database-tabs::after {
      right: 0;
      background: linear-gradient(to left, var(--color-card-bg), transparent);
      opacity: 1;
    }

    .database-tabs.scrolled-start::before {
      opacity: 0;
    }

    .database-tabs.scrolled-middle::before,
    .database-tabs.scrolled-end::before {
      opacity: 1;
    }

    .database-tabs.scrolled-end::after {
      opacity: 0;
    }
  }
</style>
