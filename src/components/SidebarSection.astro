---
/**
 * SidebarSection component - Reusable collapsible section for the sidebar.
 * Extracts common pattern used for MySQL, MSSQL, Oracle, and Extras sections.
 */
import type { CollectionEntry } from "astro:content";
import { getSortedCategories } from "../utils/entryUtils";
import { createSectionActiveChecker } from "../utils/pathUtils";

interface CategoryGroup {
  [category: string]: CollectionEntry<
    "mysql" | "mariadb" | "mssql" | "oracle" | "postgresql" | "extras"
  >[];
}

interface Props {
  /** Section identifier used in data attributes and URL paths */
  sectionId: string;
  /** Display title for the section header */
  title: string;
  /** Whether this section is currently active/expanded */
  isActive: boolean;
  /** Current URL path for highlighting active links */
  currentPath: string;
  /** Entries grouped by category (for mysql/mssql/oracle) */
  entriesByCategory?: CategoryGroup;
  /** Flat list of entries (for extras) */
  entries?: CollectionEntry<"extras">[];
  /** Whether to show categories or a flat list */
  showCategories?: boolean;
}

const {
  sectionId,
  title,
  isActive,
  currentPath,
  entriesByCategory,
  entries,
  showCategories = true,
} = Astro.props;

// Sort categories by learning progression order using shared utility
const sortedCategories = entriesByCategory ? getSortedCategories(entriesByCategory) : [];

// Create section-specific active path checker using shared utility
const isActivePath = createSectionActiveChecker(currentPath, import.meta.env.BASE_URL, sectionId);

const contentId = `sidebar-section-content-${sectionId}`;
---

<div class={`sidebar-section ${isActive ? "active" : ""}`} data-section={sectionId}>
  <button
    type="button"
    class="sidebar-heading"
    aria-expanded={isActive ? "true" : "false"}
    aria-controls={contentId}
  >
    <span>{title}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="toggle-icon"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>
  <div id={contentId} class="sidebar-items">
    <div class="sidebar-items-inner">
      {
        showCategories && entriesByCategory ? (
          sortedCategories.map((category) => (
            <div class="sidebar-category">
              <div class="category-name">{category}</div>
              <ul class="sidebar-nav">
                {entriesByCategory[category].map((entry) => (
                  <li>
                    <a
                      href={`${import.meta.env.BASE_URL}${sectionId}/${entry.id}`}
                      class={isActivePath(entry.id) ? "active" : ""}
                      aria-current={isActivePath(entry.id) ? "page" : undefined}
                    >
                      {entry.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        ) : entries ? (
          <ul class="sidebar-nav">
            {entries.map((entry) => (
              <li>
                <a
                  href={`${import.meta.env.BASE_URL}${sectionId}/${entry.id}`}
                  class={isActivePath(entry.id) ? "active" : ""}
                  aria-current={isActivePath(entry.id) ? "page" : undefined}
                >
                  {entry.data.title}
                </a>
              </li>
            ))}
          </ul>
        ) : null
      }
    </div>
  </div>
</div>
