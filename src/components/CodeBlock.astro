---
interface Props {
  code: string;
  language?: string;
  title?: string;
  highlightLines?: number[];
}

const { code, language = "sql", title, highlightLines = [] } = Astro.props;

// Split code into lines for line-level highlighting
const lines = code.split("\n");

// Normalize highlightLines to a Set for O(1) lookups
const highlightSet = new Set(highlightLines.map((n) => Number(n)));
---

<div class="modern-code-block">
  <div class="code-header">
    <span class="code-label">{title || language.toUpperCase()}</span>
    <div class="fake-buttons" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
  </div>
  <pre
    class="code-content"
    aria-label={`${language.toUpperCase()} code example`}><code class={`language-${language}`}>{
      lines.map((line, index) => {
        const lineNumber = index + 1;
        const isHighlighted = highlightSet.has(lineNumber);
        return (
          <span class={isHighlighted ? "line highlight" : "line"}>
            {line}
            {index < lines.length - 1 ? "\n" : ""}
          </span>
        );
      })
    }</code></pre>
</div>

<style>
  /* Shared .modern-code-block, .code-header, .code-label, .fake-buttons
     are in components.css to avoid duplication with SQLExample.astro */

  .code-content {
    margin: 0;
    padding: 1rem;
    background-color: var(--color-card-bg);
    overflow-x: auto;
  }

  .code-content code {
    display: block;
    white-space: pre;
  }

  .code-content .line {
    display: inline;
  }

  .code-content .line.highlight {
    display: inline-block;
    background-color: var(--color-highlight-line);
    border-left: 3px solid var(--color-accent);
    margin-left: -1rem;
    padding-left: calc(1rem - 3px);
    margin-right: -1rem;
    padding-right: 1rem;
    width: calc(100% + 2rem);
  }
</style>
