---
/**
 * NavDropdown Component
 * Reusable dropdown submenu for database categories
 * Styling consolidated in navbar.css for consistent theming
 */
import { type CollectionEntry } from "astro:content";

interface Props {
  category: string;
  entries: CollectionEntry<"mysql" | "mariadb" | "mssql" | "oracle" | "postgresql" | "extras">[];
  baseUrl: string;
  section: string;
  isActivePath: (section: string, slug: string) => boolean;
}

const { category, entries, baseUrl, section, isActivePath } = Astro.props;
---

<div
  class="dropdown-submenu"
  role="group"
  aria-labelledby={`dropdown-header-${section}-${category.toLowerCase().replace(/\s+/g, "-")}`}
>
  <div
    class="dropdown-header"
    id={`dropdown-header-${section}-${category.toLowerCase().replace(/\s+/g, "-")}`}
    role="heading"
    aria-level={4}
  >
    {category}
  </div>
  <ul class="dropdown-list">
    {
      entries.map((entry) => (
        <li>
          <a
            href={`${baseUrl}${section}/${entry.id}`}
            class:list={["dropdown-item", { active: isActivePath(section, entry.id) }]}
            aria-label={entry.data.title || `${section.toUpperCase()} ${entry.id}`}
          >
            {entry.data.title || entry.id}
          </a>
        </li>
      ))
    }
  </ul>
</div>
