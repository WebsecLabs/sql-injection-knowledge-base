{
  "name": "sqli-kb-astro",
  "type": "module",
  "version": "1.0.0",
  "description": "SQL Injection Knowledge Base",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "build:standalone": "cross-env STANDALONE=true astro build && pagefind --site dist",
    "preview": "astro preview",
    "lint": "eslint . && stylelint 'src/**/*.css' && markdownlint 'src/content/**/*.md' && prettier --check .",
    "lint:fix": "eslint --fix . && stylelint --fix 'src/**/*.css' && markdownlint --fix 'src/content/**/*.md' && prettier --write .",
    "typecheck": "astro check",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:a11y": "playwright test accessibility.spec.ts",
    "test:a11y:headed": "playwright test accessibility.spec.ts --headed",
    "test:all": "npm run test:unit && npm run test:e2e",
    "prepare": "husky"
  },
  "keywords": [
    "SQL Injection",
    "SQLi",
    "Knowledge Base",
    "Security",
    "Web Security"
  ],
  "author": "WebsecLabs",
  "license": "MIT",
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "astro": "^6.1.3",
    "rehype-slug": "^6.0.0"
  },
  "overrides": {
    "yaml": "2.8.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "markdownlint-cli": "^0.48.0",
    "pagefind": "^1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
